{
    "swagger": "2.0",
    "info": {
        "title": "SecurITe Healthcare Cloud API",
        "version": "v1",
        "description": "API for managing software updates, downloads, authentication, and status notifications for SecurITe Healthcare Cloud."
    },
    "paths": {
        "/v1/updates/{tenant-id}": {
            "post": {
                "summary": "Receive manifest of what to download",
                "description": "Device sends current versions of software components.",
                "parameters": [
                    {
                        "name": "tenant-id",
                        "in": "path",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "X-API-KEY",
                        "in": "header",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "X-DEVICE-ID",
                        "in": "header",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "software": {
                                    "type": "object",
                                    "properties": {
                                        "version": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "rules": {
                                    "type": "object",
                                    "properties": {
                                        "version": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "threat_intel": {
                                    "type": "object",
                                    "properties": {
                                        "version": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Manifest of what to download",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "software": {
                                    "type": "object",
                                    "properties": {
                                        "version": {
                                            "type": "string"
                                        },
                                        "url": {
                                            "type": "string"
                                        },
                                        "size": {
                                            "type": "integer"
                                        },
                                        "type": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "rules": {
                                    "type": "object",
                                    "properties": {
                                        "version": {
                                            "type": "string"
                                        },
                                        "url": {
                                            "type": "string"
                                        },
                                        "size": {
                                            "type": "integer"
                                        },
                                        "type": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "threat_intel": {
                                    "type": "object",
                                    "properties": {
                                        "version": {
                                            "type": "string"
                                        },
                                        "url": {
                                            "type": "string"
                                        },
                                        "size": {
                                            "type": "integer"
                                        },
                                        "type": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/download/{tenant-id}/{file-path}": {
            "get": {
                "summary": "Download a specific file",
                "description": "Download a specific file from MinIO.",
                "parameters": [
                    {
                        "name": "tenant-id",
                        "in": "path",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "file-path",
                        "in": "path",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "X-API-KEY",
                        "in": "header",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "X-DEVICE-ID",
                        "in": "header",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "File contents",
                        "schema": {
                            "type": "string",
                            "format": "binary"
                        }
                    }
                }
            }
        },
        "/v1/authenticate/{tenant-id}": {
            "get": {
                "summary": "Authenticate request",
                "description": "Authenticate request (used by Nginx).",
                "parameters": [
                    {
                        "name": "tenant-id",
                        "in": "path",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Authentication successful"
                    },
                    "401": {
                        "description": "Authentication failed"
                    }
                }
            }
        },
        "/v1/status/{tenant-id}": {
            "post": {
                "summary": "Notify status success or failure",
                "description": "Sensor updates cloud service with status.",
                "parameters": [
                    {
                        "name": "tenant-id",
                        "in": "path",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "properties": {
                                "software": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "rules": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "threat_intel": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Status notification received"
                    }
                }
            }
        }
    }
}
