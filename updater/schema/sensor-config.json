{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sensor Configuration",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "Unique tenant ID"
    },
    "api_key": {
      "type": "string",
      "description": "API key required to connect SW/TI API server"
    },
    "device_id": {
      "type": "string",
      "description": "Unique device ID"
    },
    "license_key": {
      "type": "string",
      "description": "Device license"
    }
  },
  "required": [
    "tenant_id",
    "api_key",
    "device_id",
    "license_key"
  ]
}
